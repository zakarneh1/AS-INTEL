# ------------------------------------------------------------
# AS Intel - Root .gitignore
# Keeps repository clean and review-ready for hiring teams.
# ------------------------------------------------------------

# OS / editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/

# Python
__pycache__/
*.py[cod]
*$py.class
.python-version

# Python virtual environments
.venv/
venv/
env/
ENV/

# Python tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.hypothesis/
.ipynb_checkpoints/

# Node / frontend dependencies
node_modules/
frontend/node_modules/
.pnp
.pnp.js

# Frontend build outputs and caches
build/
dist/
frontend/build/
frontend/.cache/
.cache/
*.pack

# Coverage / test artifacts
coverage/
.coverage
.coverage.*
htmlcov/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files and local secrets
.env
.env.*
!.env.example
*.pem
*token.json*
*credentials.json*

# Deployment / hosting
.vercel/

# Optional framework leftovers (safe to keep ignored)
.next/
out/
next-env.d.ts
*.tsbuildinfo
