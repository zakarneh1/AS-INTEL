{
  "name": "@emergentbase/visual-edits",
  "version": "1.0.8",
  "description": "Visual editing system — overlay, babel plugin, dev server, and integration plugins",
  "repository": {
    "type": "git",
    "url": "https://github.com/emergentbase/visual-edits.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.mjs",
      "require": "./dist/shared/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.mjs",
      "require": "./dist/types/index.js"
    },
    "./babel-plugin": {
      "types": "./dist/babel-plugin/index.d.ts",
      "require": "./dist/babel-plugin/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "require": "./dist/server/index.js"
    },
    "./craco": {
      "require": "./dist/craco-plugin.js"
    },
    "./visual-edit-overlay": "./dist/visual-edit-overlay.js"
  },
  "scripts": {
    "build": "npm run build:shared && npm run build:overlay && npm run build:babel && npm run build:server && npm run build:plugins",
    "build:shared": "tsup src/shared/index.ts --format cjs,esm --dts --out-dir dist/shared && tsup src/types/index.ts --format cjs,esm --dts --out-dir dist/types",
    "build:overlay": "esbuild src/overlay/index.ts --bundle --format=iife --global-name=visualEditOverlay --outfile=dist/visual-edit-overlay.js --minify --target=es2020",
    "build:babel": "tsup src/babel-plugin/index.ts --format cjs --dts --out-dir dist/babel-plugin",
    "build:server": "tsup src/server/index.ts --format cjs --dts --out-dir dist/server",
    "build:plugins": "tsup src/craco-plugin.ts src/webpack-plugin.ts --format cjs --dts --out-dir dist --external @emergentbase/visual-edits --external html-webpack-plugin",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "@babel/core": "^7.0.0",
    "@babel/parser": "^7.0.0",
    "@babel/traverse": "^7.0.0",
    "@babel/generator": "^7.0.0",
    "express": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@babel/core": { "optional": true },
    "@babel/parser": { "optional": true },
    "@babel/traverse": { "optional": true },
    "@babel/generator": { "optional": true },
    "express": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "esbuild": "^0.24.0",
    "tsup": "^8.3.0",
    "@types/express": "^5.0.0",
    "@types/babel__core": "^7.20.0",
    "@types/babel__traverse": "^7.20.0",
    "@types/babel__generator": "^7.6.0",
    "@babel/core": "^7.20.0",
    "@babel/generator": "^7.20.0",
    "@babel/traverse": "^7.20.0",
    "vitest": "^3.0.0",
    "jsdom": "^25.0.0"
  },
  "files": [
    "dist"
  ]
}
